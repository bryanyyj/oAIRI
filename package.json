{
  "name": "survey-app",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "db:init": "wrangler d1 execute survey-db --local --file=schema.sql",
    "wrangler:dev": "wrangler pages dev dist --d1 DB=survey-db --port 8788",
    "start": "npm run build && npm run db:init && npm run wrangler:dev"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.41",
    "tailwindcss": "^3.4.10",
    "vite": "^5.4.2",
    "wrangler": "^4.78.0"
  }
}
